OPENAI_API_KEY=...                      # OpenAI API key
JIRA_URL=https://vendasta.jira.com
JIRA_EMAIL=you@vendasta.com
JIRA_API_TOKEN=...                      # id.atlassian.com → Security → API tokens
GITHUB_TOKEN=...                        # GitHub → Settings → Developer → Personal tokens (repo scope)
GITHUB_ORG=vendasta
GITHUB_REPOS=reputation,meetings,galaxy # comma-separated repo names to search for PRs
JIRA_PROJECTS=REP,VS                    # projects included in sprint health queries
JIRA_CREATE_PROJECT=VS                  # default project for new ticket creation
GCHAT_WEBHOOK_URL=...                   # Google Chat space webhook URL (optional)

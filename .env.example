# --- Required ---
OPENAI_API_KEY=...                      # OpenAI API key — platform.openai.com → API keys

# Atlassian: ONE token works for BOTH Jira and Confluence (same account).
JIRA_URL=https://vendasta.jira.com
JIRA_EMAIL=you@vendasta.com
JIRA_API_TOKEN=...                      # id.atlassian.com → Security → Create API token

GITHUB_TOKEN=...                        # github.com → Settings → Developer settings → Personal access tokens (repo scope)
GITHUB_ORG=vendasta
GITHUB_REPOS=repo-one,repo-two          # comma-separated repos to scan; leave blank to scan the whole org

JIRA_PROJECTS=PROJ1,PROJ2               # your Jira project keys (sprint health queries)
JIRA_CREATE_PROJECT=PROJ1               # default project for new ticket creation

# NOTE: you can set JIRA_PROJECTS / JIRA_CREATE_PROJECT / GITHUB_REPOS here OR in
# your configs/<name>.yaml. If both are set, these env values win.

# --- Optional ---
# Confluence (reuses the Atlassian token above — no extra token needed).
# Only change these if you use the "wider contributions" view and your space differs.
CONFLUENCE_SPACE=RD                     # your Confluence space key
CONFLUENCE_RFC_PARENT_ID=               # parent page ID of your RFC index (leave blank if unused)

GCHAT_WEBHOOK_URL=...                   # Google Chat space webhook URL (only for digest push)

# --- Advanced (optional, sensible defaults) ---
# HOST=127.0.0.1                        # set 0.0.0.0 for container/Cloud Run
# PORT=8000
# PR_MIN_APPROVALS=2                    # approvals before a PR counts as "ready to merge"
# TOOL_CACHE_TTL=300                    # seconds to cache tool results
# DIGEST_PROJECT=PROJ1                  # project for the standalone digest.py CLI
# DIGEST_USER=                          # config user_id the digest is attributed to
